generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  hashedPassword String
  role           UserRole       @default(MEMBER)
  jobTitle       String?
  divisi         Divisi?
  employeeStatus EmployeeStatus @default(ACTIVE)
  phone          String?
  teamOrder      Int            @default(0)
  createdAt      DateTime       @default(now())

  picProjects    Project[]       @relation("PICRelation")
  memberships    ProjectMember[]
  assignedTasks  Task[]
  budgetRequests PaymentRequest[] @relation("PaymentRequestedBy")
  ownerApprovals PaymentRequest[] @relation("PaymentOwner")
  directorApprovals PaymentRequest[] @relation("PaymentDirector")
  financeDirectorApprovals PaymentRequest[] @relation("PaymentFinanceDirector")
  financeProcessed  PaymentRequest[] @relation("PaymentFinanceBy")
  budgetLockedProjects Project[]    @relation("BudgetLockedBy")
  notifications  Notification[]
  kpiReceived    KpiAssessment[] @relation("KpiUser")
  kpiGiven       KpiAssessment[] @relation("KpiEvaluator")
  projectScoresReceived ProjectScore[] @relation("ProjectScoreUser")
  personalTasks  PersonalTask[]
  progressUpdates ProgressUpdate[]
  vendorsEntered Vendor[]
  projectScoresGiven    ProjectScore[] @relation("ProjectScoreEvaluator")
  directorNotesReceived DirectorNote[] @relation("DirectorNoteTarget")
  directorNotesSent     DirectorNote[] @relation("DirectorNoteAuthor")
  auditLogs             AuditLog[]
  cashTransactions      CashTransaction[]
  opexEntries           OpexEntry[]
  assets                Asset[]
  taskComments          TaskComment[]
  salaryRecords         SalaryRecord[]

  // Quotation & Invoice relations
  quotationsCreated     Quotation[]   @relation("QuotationCreator")
  quotationsPic         Quotation[]   @relation("QuotationPic")
  quotationsApprover1   Quotation[]   @relation("QuotationApprover1")
  quotationsApprover2   Quotation[]   @relation("QuotationApprover2")
  addCostsCreated       AddCost[]     @relation("AddCostCreator")
  invoicesCreated       Invoice[]     @relation("InvoiceCreator")
}

// Global audit trail of important changes across the system, for Direksi/Owner
// and Finance Director oversight.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // e.g. PROJECT_STATUS_CHANGE, BUDGET_LOCK, BUDGET_ITEM_UPDATE, MEMBER_CHANGE
  entity    String   // e.g. Project, ProjectBudgetItem, PaymentRequest
  entityId  String?
  summary   String   // human-readable description
  meta      Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([createdAt])
}

// Simple key-value store for app-wide configurable settings (e.g. approval thresholds)
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

enum CashTransactionType {
  IN
  OUT
}

// Manual cash ledger entries (e.g. client payments received, bank transfers,
// petty cash) recorded by Finance, plus automatic OUT entries created when a
// payment request is marked as paid. Running balance = sum(IN) - sum(OUT).
model CashTransaction {
  id          String              @id @default(cuid())
  type        CashTransactionType
  amount      Float
  description String
  date        DateTime            @default(now())
  recordedById String?
  paymentRequestId String?        @unique
  createdAt   DateTime            @default(now())

  recordedBy     User?           @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  paymentRequest PaymentRequest? @relation(fields: [paymentRequestId], references: [id], onDelete: SetNull)
  debtPayment    DebtPayment?
  opexEntry      OpexEntry?
  receivableIn   Receivable?     @relation("ReceivableKasMasuk")
  receivableOut  Receivable?     @relation("ReceivableKasKeluar")

  @@index([date])
}

// Monthly operational expenses (rent, utilities, salaries, subscriptions,
// etc.). Each entry mirrors a CashTransaction (OUT) so the cash ledger stays
// consistent — deleting an OpexEntry also removes its cash entry.
model OpexEntry {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Float
  date        DateTime
  period      String // YYYY-MM, for monthly summaries
  recordedById String?
  cashTransactionId String? @unique
  createdAt   DateTime @default(now())

  recordedBy      User?            @relation(fields: [recordedById], references: [id], onDelete: SetNull)
  cashTransaction CashTransaction? @relation(fields: [cashTransactionId], references: [id], onDelete: SetNull)

  @@index([period])
}

enum AssetCategory {
  VEHICLE
  ELECTRONICS
  EQUIPMENT
  PROPERTY
  FURNITURE
  SOFTWARE
  CRYPTO
  OTHER
}

enum AssetCondition {
  BAIK
  RUSAK_RINGAN
  RUSAK_BERAT
}

// Company fixed-asset register — acquisition cost vs. current value gives a
// running depreciation figure per asset and in aggregate.
model Asset {
  id               String         @id @default(cuid())
  name             String
  category         AssetCategory
  condition        AssetCondition @default(BAIK)
  acquisitionCost  Float
  currentValue     Float
  acquisitionDate  DateTime
  notes            String?
  createdById      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

enum DebtStatus {
  ACTIVE
  PAID_OFF
}

enum DebtPaymentStatus {
  PENDING
  PAID
}

enum ReceivableStatus {
  UNPAID
  PAID
}

// Outstanding invoices to clients (piutang) — tracked so Direksi/Finance can
// monitor how much revenue is invoiced but not yet collected.
model Receivable {
  id                 String           @id @default(cuid())
  projectId          String?
  invoiceNumber      String?
  poNumber           String?          // Nomor PO dari klien (opsional)
  taxInvoiceNumber   String?          // Nomor faktur pajak (opsional)
  clientName         String           // Nama klien (versi finance — bisa beda dengan nama di sistem)
  financeProjectName String?          // Nama project versi klien/finance (untuk invoice)
  amount             Float            // Nilai invoice
  issueDate          DateTime?
  dueDate            DateTime?
  status             ReceivableStatus @default(UNPAID)
  paidAt             DateTime?
  paidAmount         Float?           // Nominal aktual yang diterima (setelah PPh/penyesuaian)
  pphAmount          Float    @default(0)  // PPh yang dipotong klien → jadi Kas Keluar
  isDraft            Boolean  @default(false)  // true = otomatis dari project, belum dikonfirmasi finance
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project                  Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  kasTransactionIn         CashTransaction? @relation("ReceivableKasMasuk",  fields: [kasTransactionInId],  references: [id])
  kasTransactionInId       String?          @unique
  kasTransactionOut        CashTransaction? @relation("ReceivableKasKeluar", fields: [kasTransactionOutId], references: [id])
  kasTransactionOutId      String?          @unique
  invoiceId                String?
  invoice                  Invoice?         @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([projectId])
  @@index([invoiceId])
}

// Company debt/loan obligations (e.g. from investors, banks, profit-sharing
// arrangements) — tracked so Owner & Finance stay aware of monthly principal +
// interest obligations and how they affect cash flow.
model Debt {
  id              String     @id @default(cuid())
  lenderName      String
  principal       Float
  interestRate    Float      @default(0) // bunga / bagi hasil per bulan (% dari pokok)
  monthlyInterest Float      @default(0) // bunga / bagi hasil per bulan (nominal, dihitung dari interestRate)
  tenorMonths     Int
  startDate       DateTime
  notes           String?
  status          DebtStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  payments DebtPayment[]
}

// One installment row per month of a Debt's tenor — generated automatically
// when the debt is created.
model DebtPayment {
  id              String            @id @default(cuid())
  debtId          String
  installmentNo   Int
  dueDate         DateTime
  principalAmount Float
  interestAmount  Float
  status          DebtPaymentStatus @default(PENDING)
  paidAt          DateTime?
  cashTransactionId String?         @unique
  createdAt       DateTime          @default(now())

  debt           Debt             @relation(fields: [debtId], references: [id], onDelete: Cascade)
  cashTransaction CashTransaction? @relation(fields: [cashTransactionId], references: [id], onDelete: SetNull)

  @@index([dueDate])
}

// Annual revenue/project-count targets per division, set by the Owner for
// tracking organizational direction and progress.
model DivisionTarget {
  id               String   @id @default(cuid())
  year             Int
  division         Divisi
  revenueTarget    Float    @default(0)
  projectCountTarget Int    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([year, division])
}

// Anonymous note from a team member to a director. The author is hidden from the
// director — only OWNER and HR (Finance/HRGA director) can see who wrote it.
model DirectorNote {
  id         String   @id @default(cuid())
  directorId String
  authorId   String
  message    String
  createdAt  DateTime @default(now())

  director User @relation("DirectorNoteTarget", fields: [directorId], references: [id], onDelete: Cascade)
  author   User @relation("DirectorNoteAuthor", fields: [authorId], references: [id], onDelete: Cascade)
}

model ProjectScore {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  evaluatorId String
  criteria    String
  score       Int
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectScoreUser", fields: [userId], references: [id], onDelete: Cascade)
  evaluator User    @relation("ProjectScoreEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, evaluatorId, criteria])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KpiAssessment {
  id          String   @id @default(cuid())
  userId      String
  evaluatorId String
  period      String
  kpiKey      String
  score       Int
  comment     String?
  late        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User @relation("KpiUser", fields: [userId], references: [id], onDelete: Cascade)
  evaluator User @relation("KpiEvaluator", fields: [evaluatorId], references: [id], onDelete: Cascade)

  @@unique([userId, evaluatorId, period, kpiKey])
}

model KpiCriterion {
  id        String   @id @default(cuid())
  role      UserRole
  division  Divisi?
  key       String
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, division, key])
}

model ScoreCriterion {
  id        String   @id @default(cuid())
  division  Divisi?
  key       String
  label     String
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([division, key])
}

// Configurable workload-score weights per project status — how much a stage
// counts toward a person's workload, separately for the PIC vs other members
// (since not every stage requires every member's involvement).
model WorkloadWeight {
  id           String        @id @default(cuid())
  status       ProjectStatus @unique
  picWeight    Float
  memberWeight Float
  updatedAt    DateTime      @updatedAt
}

enum UserRole {
  OWNER
  PROJECT_MANAGER
  PRODUCTION
  PROJECT_OFFICER
  CREATIVE_LEAD
  GRAPHIC_DESIGNER
  STAGE_DESIGNER
  CONTENT_CREATOR
  INTERNSHIP
  MEMBER
  DIRECTOR
  FINANCE
  FINANCE_STAFF
  PRODUCER
  EDITOR
}

enum Divisi {
  EVENT
  CREATIVE
  PH
  FINANCE_HRGA
}

enum EmployeeStatus {
  ACTIVE
  NOT_ACTIVE
}

model Client {
  id        String    @id @default(cuid())
  name      String    @unique
  industry  String?
  contact   String?
  notes     String?
  createdAt DateTime  @default(now())

  projects  Project[]
  contacts  ClientContact[]
}

// Individual PIC contacts for a client — a client can have multiple PICs
// (procurement, marketing, finance, etc.). Captures details useful for
// relationship management, including info needed for holiday gift lists.
model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  jobTitle  String?
  email     String?
  phone     String?
  address   String?
  religion  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Vendor database — searchable directory of external vendors (venues, talent,
// production, merchandise, etc.) used when sourcing for projects. "Entered by"
// is auto-derived from the logged-in account, so it's reliable for follow-up.
model Vendor {
  id            String   @id @default(cuid())
  name          String
  vendorType    String
  subCategory   String?
  province      String?
  city          String?
  address       String?
  area          String?
  capacity      String?
  ballroomCapacity String?
  meetingCapacity  String?
  website       String?
  instagram     String?
  output        String?
  productService String?
  status        String   @default("Active")
  picContact    String?
  phone         String?
  priceMin      Float?
  priceMax      Float?
  priceNote     String?
  notes         String?
  photos        Json?
  enteredById   String?
  enteredByName String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  enteredBy User? @relation(fields: [enteredById], references: [id], onDelete: SetNull)

  @@index([vendorType])
  @@index([city])
}

model Project {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  clientId        String?
  category        String
  budgetTier      BudgetTier?
  eventComplexity EventComplexity?
  recommendation  Recommendation?
  division        Divisi          @default(EVENT)
  picId           String?
  briefDate       DateTime?
  submitDate      DateTime?
  pitchDuration   Int?
  startDate       DateTime?
  endDate         DateTime?
  loadInDays      Int?            @default(0)
  projectDuration Int?
  status          ProjectStatus   @default(HOLD)
  pitchStatus     PitchStatus?
  pitchResult     PitchResult?
  wonLossReason   String?
  vendorWinner    String?
  evaluationNote  String?
  projectValue    Float?
  includesPpn     Boolean @default(false)
  quotationNumber String?
  quotationFileUrl  String?
  quotationFileName String?
  invoiceNumber   String?
  budgetLockedAt  DateTime?
  budgetLockedById String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  client    Client?         @relation(fields: [clientId], references: [id])
  pic       User?           @relation("PICRelation", fields: [picId], references: [id])
  budgetLockedBy User?       @relation("BudgetLockedBy", fields: [budgetLockedById], references: [id])
  members   ProjectMember[]
  tasks     Task[]
  personalTasks PersonalTask[]
  budgets   ProjectBudget[]
  budgetItems ProjectBudgetItem[]
  payments  PaymentRequest[]
  receivables Receivable[]
  quotations  Quotation[]
  scores    ProjectScore[]
  briefItems ProjectBriefItem[]

  @@index([status])
  @@index([division])
  @@index([picId])
  @@index([updatedAt])
  @@index([clientId])
}

model ProjectBriefItem {
  id        String   @id @default(cuid())
  projectId String
  order     Int      @default(0)
  question  String
  answer    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum ProjectStatus {
  HOLD
  PITCHING
  WAITING_PITCH_RESULT
  PREPARATION
  EVENT_DAY
  REPORTING
  INVOICING
  DONE
  FAILED
  CANCELED
}

enum PitchStatus {
  PITCH
  PITCH_PLUS
  AUTO_WIN
  CANCEL_PROJECT
}

enum PitchResult {
  WIN
  LOSE
  NOT_FINAL
}

enum ProjectCategory {
  MEETING_CONFERENCE
  ACTIVATION
  LAUNCHING
  EXHIBITION
  INCENTIVE_GATHERING
  SPONSORSHIP
  // Production House (PH) categories
  CORPORATE_PROFILE_BRANDING
  COMMERCIAL_ADVERTISING
  EVENT_DOCUMENTATION_HIGHLIGHT
  SOCIAL_MEDIA_CONTENT
  TRAINING_INTERNAL_COMMUNICATION
  PRODUCT_EXPLAINER_VIDEO
  MOTION_GRAPHIC_ANIMATION
  DOCUMENTARY_STORYTELLING
}

enum BudgetTier {
  LOW
  MEDIUM
  HIGH
}

enum EventComplexity {
  SIMPLE
  MEDIUM
  COMPLEX
  HIGH
}

enum Recommendation {
  MAINTAIN
  PRIORITIZE
  EVALUATE
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  description String?
  assigneeId  String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  openEnded   Boolean    @default(false)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee     User?            @relation(fields: [assigneeId], references: [id])
  dependencies TaskDependency[] @relation("DependentTask")
  dependents   TaskDependency[] @relation("RequiredTask")

  progressUpdates ProgressUpdate[]
  comments        TaskComment[]

  @@index([projectId])
}

// Discussion thread on a project task — team members can comment and @mention
// each other; mentioned users (and the task assignee) get a notification.
model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

enum TaskStatus {
  TODO
  BLOCKED
  IN_PROGRESS
  DONE
}

enum ProgressStatus {
  ON_TRACK
  DELAYED
  HOLD
  PROBLEM
  DONE
}

// Manual to-do items added by each user, separate from project tasks.
model PersonalTask {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  dueDate     DateTime?
  status      TaskStatus @default(TODO)
  order       Int        @default(0)
  projectId   String?
  clientName  String?
  projectName String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  progressUpdates ProgressUpdate[]

  @@index([userId])
}

// Daily progress check-in submitted by a user for an assigned project task or
// a personal to-do item. One entry per item per calendar day. Used both to
// show progress history and to compute monthly performance deductions when
// updates are missing or status is Delayed/Hold/Problem.
model ProgressUpdate {
  id             String         @id @default(cuid())
  taskId         String?
  personalTaskId String?
  userId         String
  date           DateTime
  status         ProgressStatus
  note           String?
  late           Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  task         Task?         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  personalTask PersonalTask? @relation(fields: [personalTaskId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId, date])
  @@unique([personalTaskId, userId, date])
  @@index([userId, date])
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ExpenseCategory {
  TICKET_TRANSPORT
  ACCOMMODATION
  VENUE_DP
  VENUE_FINAL
  VENDOR_DP
  VENDOR_FINAL
  TALENT_HONOR
  OPERATIONAL_OTHER
}

enum PaymentStatus {
  PENDING_DIRECTOR        // legacy: Awaiting division director (Event/PH/Creative) approval
  PENDING_OWNER           // 0. Request submitted by a division director: awaiting Owner approval first
  PENDING_FINANCE_DIRECTOR // 1. Awaiting Finance & HRGA Director (Anung) approval
  APPROVED_BY_DIRECTOR    // 2. Approved, awaiting payment execution (Antoni/Anung)
  REJECTED
  PAID
}

enum PaymentTerm {
  DP
  PELUNASAN
  FULL
}

model ProjectBudget {
  id        String          @id @default(cuid())
  projectId String
  category  ExpenseCategory
  amount    Float
  neededDate DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, category])
}

// Custom, free-form budget line items (matched to client quotation lines), each with
// a quoted (forecast) amount vs. the actual capital needed in the field, plus its
// timing — gives Finance a forecast and surfaces forecast-vs-actual variance for the PM.
model ProjectBudgetItem {
  id            String    @id @default(cuid())
  projectId     String
  label         String
  category      ExpenseCategory @default(OPERATIONAL_OTHER)
  quotedAmount  Float     @default(0)
  qty           Float?
  unitPrice     Float?
  needsUpfrontFunding Boolean @default(false)
  actualAmount  Float?
  neededDate    DateTime?
  note          String?
  reminderSentAt DateTime?
  order         Int       @default(0)
  // Titipan klien: budget pass-through yang tidak dihitung sebagai revenue Watermark
  isTitipan     Boolean   @default(false)
  titipanNote   String?   // catatan umum (mis: "titipan hutang klien ke vendor lama")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project         Project                        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  payments        PaymentRequest[]
  titipanEntries  ProjectBudgetItemTitipanEntry[]

  @@index([projectId])
}

// Rincian vendor per item titipan — satu item bisa mencakup banyak vendor
model ProjectBudgetItemTitipanEntry {
  id           String    @id @default(cuid())
  budgetItemId String
  vendorName   String
  amount       Float     @default(0)
  note         String?   // mis: "hutang dari project Agustus 2025 – invoice #INV-123"
  isPaid       Boolean   @default(false)
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  budgetItem ProjectBudgetItem @relation(fields: [budgetItemId], references: [id], onDelete: Cascade)

  @@index([budgetItemId])
}

model PaymentRequest {
  id              String          @id @default(cuid())
  projectId       String
  requestedById   String
  category        ExpenseCategory
  budgetItemId    String?
  amount          Float
  vendor          String?
  recipientName    String?
  recipientAccount String?
  paymentTerm      PaymentTerm     @default(FULL)
  description     String?
  neededDate      DateTime?
  status          PaymentStatus   @default(PENDING_FINANCE_DIRECTOR)
  ownerId         String?
  ownerNote       String?
  ownerApprovedAt DateTime?
  directorId      String?
  directorNote    String?
  approvedAt      DateTime?
  financeDirectorId   String?
  financeDirectorNote String?
  financeApprovedAt   DateTime?
  financeById     String?
  financeNote     String?
  paidAt          DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User               @relation("PaymentRequestedBy", fields: [requestedById], references: [id])
  owner       User?              @relation("PaymentOwner", fields: [ownerId], references: [id])
  director    User?              @relation("PaymentDirector", fields: [directorId], references: [id])
  financeDirector User?          @relation("PaymentFinanceDirector", fields: [financeDirectorId], references: [id])
  financeBy   User?              @relation("PaymentFinanceBy", fields: [financeById], references: [id])
  budgetItem  ProjectBudgetItem? @relation(fields: [budgetItemId], references: [id])
  cashTransaction CashTransaction?

  @@index([status])
  @@index([projectId])
  @@index([createdAt])
}

model TaskDependency {
  id              String @id @default(cuid())
  dependentTaskId String
  requiredTaskId  String

  dependentTask Task @relation("DependentTask", fields: [dependentTaskId], references: [id], onDelete: Cascade)
  requiredTask  Task @relation("RequiredTask", fields: [requiredTaskId], references: [id], onDelete: Cascade)

  @@unique([dependentTaskId, requiredTaskId])
}

// ── Payroll / Salary ──────────────────────────────────────────────────────────
// Monthly salary record per employee. One row per user per period (YYYY-MM).
// Komponen sesuai slip gaji WTM: gaji pokok + tunjangan – potongan = THP.
model SalaryRecord {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  period             String   // "2026-06"
  employeeId         String?  // "001", "002", dst

  // ── Komponen Gaji (penambah) ──
  gajiPokok          Float    @default(0)
  tunjanganJabatan   Float    @default(0)
  tunjanganKinerja   Float    @default(0)
  tunjanganTransport Float    @default(0)
  tunjanganProject   Float    @default(0)  // tunjangan project (bukan bonus)
  bonusProject       Float    @default(0)  // bonus project (invoice sudah keluar)
  thrBonus           Float    @default(0)  // THR / bonus tahunan / insentif lain

  // ── Potongan (pengurang) ──
  bpjsTk             Float    @default(0)  // BPJS Ketenagakerjaan
  bpjsKes            Float    @default(0)  // BPJS Kesehatan
  bpjsKesKeluarga    Float    @default(0)  // BPJS Kes. Keluarga
  pph21              Float    @default(0)  // PPh 21
  kasbon             Float    @default(0)  // Kasbon / pinjaman
  absen              Float    @default(0)  // Potongan absen

  // ── Info Rekening ──
  bank               String?              // "BCA", "BRI", dll
  nomorRekening      String?

  notes              String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, period])
  @@index([period])
}

// ── Quotation & Invoice System ────────────────────────────────────────────────

// Auto-incrementing counter per division per year, for quotation numbering.
// e.g. WTM/EO/QUOT/2026/073
model QuotationCounter {
  division String
  year     Int
  lastNum  Int    @default(0)

  @@id([division, year])
}

enum QuotationStatus {
  DRAFT
  PENDING_WULAN      // Waiting for Wulan's approval
  PENDING_DIRECTOR   // Waiting for Director's approval (David / Guna)
  APPROVED           // Approved — can be sent to client
  WON
  LOST
  CANCELLED
}

enum InvoiceMode {
  DETAIL   // Full item breakdown
  SUMMARY  // Single service line (no detail)
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

// Quotation document sent to clients before a project is won.
// Number format: WTM/EO/QUOT/2026/073  |  WTM/PH/QUOT/2026/012
// Version is internal only — the same number is reused across revisions until WON.
// Post-WON supplemental items use AddCost with a separate numbering scheme.
model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          // e.g. WTM/EO/QUOT/2026/073
  division        Divisi          @default(EVENT)
  version         Int             @default(1)  // internal revision counter
  status          QuotationStatus @default(DRAFT)

  // Client & Event information (shown on document)
  clientName      String
  eventName       String
  venue           String?
  eventDate       String?   // flexible: "12-14 Juni 2026"
  location        String?   // city / venue name for document header

  // Agency fee — optional, applied only to items with includeAgencyFee = true
  agencyFeePercent Float    @default(0)   // e.g. 10 = 10%

  // PPN
  includesPpn     Boolean  @default(false)
  ppnPercent      Float    @default(11)

  // Down payment options (when DP termin is needed)
  dpPercent       Float?   // e.g. 30 = 30% DP
  dpAmount        Float?   // fixed DP amount (alternative to dpPercent)

  // "Prepared by" on the printed document — may differ from createdBy.
  // e.g. David creates the quotation but Irham's name appears as Prepared by.
  picQuotationId  String?
  picQuotation    User?    @relation("QuotationPic", fields: [picQuotationId], references: [id])

  // Actual creator (internal only, not shown on document)
  createdById     String
  createdBy       User     @relation("QuotationCreator", fields: [createdById], references: [id])

  // Approval chain — both names appear in the signature block
  approver1Id     String?  // Wulan Aprilia (intermediate approver)
  approver1       User?    @relation("QuotationApprover1", fields: [approver1Id], references: [id])
  approver2Id     String?  // Director: David Setyawan / Guna
  approver2       User?    @relation("QuotationApprover2", fields: [approver2Id], references: [id])

  // Link to project (set when quotation is WON and project exists)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id])

  notes           String?
  termsConditions String?  // custom T&C override (null = use system default)

  sections  QuotationSection[]
  addCosts  AddCost[]
  invoices  Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([division])
  @@index([createdById])
  @@index([projectId])
}

// Category group within a quotation, labeled alphabetically: A, B, C...
// e.g. A = VENUE, B = CREATIVE & MULTIMEDIA, C = PRODUCTION, D = SOUVENIR
model QuotationSection {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  letter      String    // A, B, C, D...
  name        String    // VENUE | CREATIVE & MULTIMEDIA | PRODUCTION | etc.
  order       Int

  items QuotationItem[]

  @@index([quotationId])
}

// Line item inside a quotation section.
// Formula: rate × qty × days = subtotal
// rate = null → "by client" (item is present but cost is client-provided, not charged)
model QuotationItem {
  id          String           @id @default(cuid())
  sectionId   String
  section     QuotationSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  no          Int     // item number within section (1, 2, 3…)
  description String
  detailText  String? // multi-line detail shown below description on document

  // Pricing
  rate        Float?           // null = "by client" (no charge)
  unitType    String  @default("Unit")  // Package | Pcs | Pax | Unit | Set | Lot | Event
  qty         Float   @default(1)
  days        Float   @default(1)
  subtotal    Float   @default(0)      // rate × qty × days; 0 if by client

  // Agency fee applies to this item only if true
  includeAgencyFee    Boolean @default(false)

  // Controls visibility in invoice DETAIL mode
  showInInvoiceDetail Boolean @default(true)

  order Int

  @@index([sectionId])
}

// Post-WON supplemental cost — issued after the quotation is already won.
// Number format: WTM/EO/ADDCOST/2026/073/01
// Each AddCost belongs to an existing Quotation.
model AddCost {
  id            String    @id @default(cuid())
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id])
  addCostNumber String    // e.g. WTM/EO/ADDCOST/2026/073/01
  description   String
  amount        Float
  notes         String?
  createdById   String
  createdBy     User      @relation("AddCostCreator", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([quotationId])
}

// Invoice issued to client, generated from a WON Quotation.
// Number format: WTM/EO/INV/2026/073/001  (last segment = termin number)
// One quotation can produce multiple invoices (DP + Pelunasan).
// Finance can override client/event names (financeClientName, financeEventName)
// without changing the original quotation data.
model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        // e.g. WTM/EO/INV/2026/073/001
  quotationId    String
  quotation      Quotation     @relation(fields: [quotationId], references: [id])
  termNumber     Int           @default(1) // 1 = Full or DP; 2 = Pelunasan

  // Finance-side naming (may differ from quotation for client's reference system)
  financeClientName String?
  financeEventName  String?

  // Client-side document reference numbers
  poNumber         String?
  taxInvoiceNumber String?

  // Finance PIC shown on invoice document
  picFinanceName   String?
  picFinancePhone  String?

  // PDF output mode
  mode    InvoiceMode   @default(DETAIL)
  isDP    Boolean       @default(false)  // true if this is a DP termin invoice

  // Totals (stored so PDF can render without recalculating)
  subtotal        Float @default(0)
  agencyFeeAmount Float @default(0)
  ppnAmount       Float @default(0)
  totalAmount     Float @default(0)

  issueDate DateTime?
  dueDate   DateTime?
  status          InvoiceStatus @default(DRAFT)
  notes           String?
  termsConditions String?  // custom T&C shown at bottom of PDF (null = use division default)

  createdById String
  createdBy   User   @relation("InvoiceCreator", fields: [createdById], references: [id])

  items       InvoiceItem[]
  receivables Receivable[]  // 1 invoice → 1 or 2 receivable entries (DP + pelunasan)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quotationId])
  @@index([status])
}

// Invoice line items — copied from QuotationItems when the invoice is created.
// Finance can toggle showInDetail per item to control what appears in DETAIL mode PDF.
model InvoiceItem {
  id               String  @id @default(cuid())
  invoiceId        String
  invoice          Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description      String
  detailText       String?
  rate             Float?
  unitType         String  @default("Unit")
  qty              Float   @default(1)
  days             Float   @default(1)
  subtotal         Float   @default(0)
  includeAgencyFee Boolean @default(false)
  showInDetail     Boolean @default(true)
  order            Int

  @@index([invoiceId])
}
